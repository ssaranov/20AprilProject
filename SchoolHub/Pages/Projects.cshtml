@page
@model SchoolHub.Pages.ProjectsModel
@{
	ViewData["Title"] = "Проекты";
}

<div class="container mt-5">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="mb-0">All projects</h1>
		<span class="badge bg-dark fs-6">
			Total projects: @Model.TotalProjectsCount
		</span>
	</div>

	@if(!string.IsNullOrEmpty(Model.Message))
	{
		<div class="alert alert-warning">
			@Model.Message
		</div>
	}
	<div class="card shadow mb-4">
		<div class="card-body">
			<h3 class="mb-3">Добавить проект</h3>
			
			<form method="post" asp-page-handler="Add">
				<div class="mb-3">
					<label class="form-label">Название проекта</label>
					<input asp-for="Title" class="form-control" />
				</div>
				
				<div class="mb-3">
					<label class="form-label">Описание</label>
					<input asp-for="Description" class="form-control" rows="4" />
				</div>

				<div class="mb-3">
					<label class="form-label">Категория</label>
					<input asp-for="Category" class="form-control" rows="4" />
					<select asp-for="Category" class="form-select">
						<option value="">
							Select category
						</option>
						@foreach (var category in Model.Categories)
						{
							<option value="@category">
								@category
							</option>			
						}
					</select>
				</div>

				<div class="mb-3">
					<label class="form-label">Статус</label>
					<select asp-for="Status" class="form-select">
						@foreach (var status in Model.Statues)
						{
							<option value="@status">
								@status
							</option>
						}
					</select>
				</div>
			
				<button type="submit" class="btn btn-success">Добавить проект.</button>
			</form>
		</div>
	</div>
	<h3 class="mb-3">Список проектов:</h3>
	@if(Model.Projects.Count == 0)
	{
		<div class="alert alert-info">
				Пока проектов нет.
		</div>
	}
	else
	{
		<div class="row">
		@foreach(var project in Model.Projects)
		{
			<div class="col-mb-6 mb-4">
				<div class="card mb-3 h-100 shadow-sm">
					<h4 class="mb-4 card-title"@project.Title>@project.Title</h4>
					<p class="mb-2">
						<span class="badge bg-primary">@project.Category</span>
						<span class="badge bg-secondary">@project.Status</span>
					</p>
					<p class="card-text">@project.Description</p>

					<div class="card-footer">
						<small class="d-block text-muted">
							Автор: @project.Author?.Name
						</small>
							<small class="d-block text-muted">
							Дата создание: @project.CreatedAt.ToString("dd.MM.yyyy HH:mm");
						</small>
							<a asp-page="/ProjectDetails" asp-route-id="@project.Id" class="btn btn-outline-primary btn-sm">
								Открыть
							</a>
					</div>
				</div>
			</div>
		}
		</div>
	}
	
</div>