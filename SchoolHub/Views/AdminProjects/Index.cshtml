@model List<SchoolHub.Models.Project>

@{
    ViewData["Title"] = "MVC Админка проектов";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">MVC админка проектов</h1>
            <p class="text-muted mb-3">
                ааббб
            </p>
        </div>
        <span class="badge bg-dark fs-6">
            Всего проектов: @Model.Count
        </span>
    </div>

    @if (Model.Count == 0)
    {
            <div class="alert alert-info">
                Проектов нет
            </div>
    }
    else
    {
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Название</th>
                        <th>Категория</th>
                        <th>Статус</th>
                        <th>Автор</th>
                        <th>Дата</th>
                        <th style="width: 260px">Действие</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var project in Model)
                {
                            <tr>
                                <td>@project.Title</td>
                                <td>@project.Category</td>
                                <td>@project.Status</td>
                                <td>@project.Author?.Name</td>
                                <td>@project.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-controller="AdminProjects" asp-action="Details" asp-route-id="@project.Id" class="btn btn-outline-primary btn-sm">Открыть</a>
                                        <a asp-controller="AdminProjects" asp-action="Edit" asp-route-id="@project.Id" class="btn btn-outline-warning btn-sm">Изменить</a>
                                        <a asp-controller="AdminProjects" asp-action="Delete" asp-route-id="@project.Id" class="btn btn-outline-danger btn-sm">Удалить</a>
                                    </div>
                                </td>
                            </tr>
                }
                </tbody>
            </table>
    }
</div>
